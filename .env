# Market Analysis Settings
MARKET_MIN_DAILY_VOLUME=1000000
MARKET_LOOKBACK_MINUTES=60

# Consecutive Bars Analysis - Downward Tolerance
# Allows slight downward movement in bars while still considering the trend as upward
# This helps filter out minor market noise while maintaining trend integrity
# Example: 0.1 means allow up to 10% downward movement in any single bar
# Set to 0.0 for strict upward movement only
MARKET_CONSECUTIVE_BARS_DOWNWARD_TOLERANCE_PCT=0.1

# Pre-Analysis Filtering (Based on Historical Pattern Analysis)
# Enable filtering based on volume patterns observed before analysis time
# This can improve success rate by filtering out likely negative performers
MARKET_ENABLE_PRE_ANALYSIS_FILTERING=true

# Volume ratio threshold: early volume (first 15 min) / later volume (last 15 min)
# Lower ratios allow for volume buildup patterns which can indicate strong momentum
# Relaxed from 1.3 to 0.5 to catch more explosive moves like TGL (+157%)
MARKET_PRE_ANALYSIS_MIN_VOLUME_RATIO=0.5

# Buy Signals Stop Loss Buffer (percentage below the candle low)
# Example: 0.5 means stop loss is 0.5% below the candle low
BUY_SIGNAL_STOP_LOSS_BUFFER_PCT=0.5


# DEV or PROD webull credentials
AUTO_BUY_ALERTS=true

# =============================================================================
# General Entry Score Configuration
# =============================================================================
ENTRY_SCORE_MIN=80
ENTRY_SCORE_MAX=100
ENTRY_SCORE_LIMIT=3

# 2026-02-27: Lowered from 0.65 to 0.60 with new enhanced model calibration
SCORE_BELL=0.60

# =============================================================================
# Market Movers Universe Expansion
# =============================================================================
# Add explosive intraday movers (4%+ gains) to pipeline universes
# Set to 0 to disable, or specify number of top movers to add (e.g., 100)
# Data auto-populated daily at 5 PM CST from five_minute_prices table
# Service automatically falls back to most recent trading day

PIPELINE_A_ADD_MOVERS=100
PIPELINE_B_ADD_MOVERS=100
PIPELINE_C_ADD_MOVERS=0
PIPELINE_D_ADD_MOVERS=0
PIPELINE_E_ADD_MOVERS=0
PIPELINE_F_ADD_MOVERS=100
PIPELINE_G_ADD_MOVERS=0
PIPELINE_H_ADD_MOVERS=0
PIPELINE_I_ADD_MOVERS=0
PIPELINE_J_ADD_INTRADAY_UNIVERSE=true
PIPELINE_K_ADD_MOVERS=0
PIPELINE_M_ADD_MOVERS=0
PIPELINE_N_ADD_MOVERS=0
PIPELINE_BIASED1_ADD_MOVERS=0

# Realtime candidate pipeline
TRADING_REALTIME_ENABLED=true
TRADING_REALTIME_LOOP_SLEEP_MS=500
TRADING_WATCH_SYMBOLS_LIMIT=5000

# Pipeline letter assigned to realtime alerts.
# Determines which ML model scores them (resolved via ScoreTradeAlertWithMl).
# A → winner_model_momentum.joblib      B → winner_model_pipeline_b.joblib
# C → winner_model_breakouts.joblib     D/H/I → winner_model_pipeline_hid.joblib
# J → winner_model_pipeline_j.joblib    L → winner_model_pipeline_l.joblib
TRADING_REALTIME_PIPELINE_RUN=H
TRADING_REALTIME_SCORE_JOB_CLASS=App\Jobs\ScoreTradeAlertWithMl

# Optional: custom entry finder (instead of default realtime trigger)
TRADING_REALTIME_ENTRY_FINDER_CLASS=App\Services\Trading\Realtime\RealtimeMomentumContinuationFinder

# Redis/cache freshness
# 2026-06-25: 5s — tight freshness for realtime momentum entries
TRADING_MAX_QUOTE_AGE_SECONDS=15
TRADING_QUOTE_CACHE_TTL_SECONDS=15
TRADING_PARTIAL_BAR_CACHE_TTL_SECONDS=90

# Candidate rules
# 2026-06-24: Lowered from 600 → 300 — 10-min stale setups lose their momentum edge
TRADING_CANDIDATE_TTL_SECONDS=300
# 2026-06-24: Raised from 35 → 58 — 35 was far too permissive (default 70), flooding the candidate pool with noise
# 2026-06-25 changed from 58 to 25 just to see entries that system is working
# Changed back to 58 after was able to see some trades go complete through to placing order
TRADING_EARLY_SCORE_MIN=65
TRADING_MIN_DOLLAR_VOLUME_1M=10000
TRADING_MAX_SPREAD_PCT=0.35
TRADING_MAX_VWAP_EXTENSION_PCT=1.25

# Fresh/no-chase rules
TRADING_MAX_ENTRY_AGE_SECONDS=60
TRADING_MAX_MOVE_SINCE_ENTRY_PCT=0.35
TRADING_MAX_MOVE_SINCE_CANDIDATE_PCT=0.75

# Default entry trigger if no custom finder is configured
TRADING_ENTRY_VOLUME_RATIO_MIN=1.50
# 2026-06-24: Raised from 0.10 → 0.20 — 0.10% is noise-level, 0.20% better confirms real momentum
TRADING_ENTRY_RETURN_1M_MIN_PCT=0.10
TRADING_ENTRY_ABOVE_CANDIDATE_MIN_PCT=-0.10

# Optional: connect this to your existing finder/scoring pipeline
# Already configured above: TRADING_REALTIME_ENTRY_FINDER_CLASS

# Optional HTTP ingest endpoints
INTERNAL_MARKET_DATA_SECRET=aoujga90g809iagf08

# Existing table names if yours differ
TRADING_ASSET_INFO_TABLE=asset_info
TRADING_ONE_MINUTE_PRICES_TABLE=one_minute_prices
TRADING_TRADE_ALERTS_TABLE=trade_alerts
TRADING_ASSET_INFO_ONE_MIN_COLUMN=1_min

REDIS_QUEUE_RETRY_AFTER=300



TRADING_ML_PIPELINE_EXTERNAL_MODEL_PATH=python_ml/v2/models/winner_model_all_pipelines.joblib

ALPACA_STREAM_REDIS_WORKER_ENABLED=true
ALPACA_WORKER_REDIS_PREFIX=alpaca_bot
ALPACA_WORKER_REDIS_STREAM_PARTITIONS=16
ALPACA_WORKER_REDIS_STREAM_MAXLEN=250000

TRADE_ALERT_EXTERNAL_VERSION=ext-v1.0
TRADING_ML_SCORER_SCRIPT_PIPELINE_MANUAL=python_ml/v2/score_single_alert_v2.py

ALPACA_BOT_REDIS=false
